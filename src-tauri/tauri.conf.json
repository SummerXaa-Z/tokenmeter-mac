{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeepSeekMonitorMac",
  "version": "1.1.0",
  "identifier": "com.deepseek.monitor.mac",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5180",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "DeepSeek Monitor",
        "width": 356,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
